## Using Elysia's Test Utilities

For API tests, use Elysia's built-in `handle` method instead of starting a real HTTP server:

```ts
import { describe, expect, it, beforeEach } from 'vitest'
import { app } from '$api/index'   // the Elysia app instance

describe('POST /api/v1/assets', () => {
  let sessionCookie: string

  beforeEach(async () => {
    // Log in and get a session cookie
    const loginResponse = await app.handle(
      new Request('http://localhost/api/v1/auth/login', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email: 'gso@test.local', password: 'testpassword' }),
      })
    )
    sessionCookie = loginResponse.headers.get('set-cookie') ?? ''
  })

  it('creates an asset and returns 201', async () => {
    const response = await app.handle(
      new Request('http://localhost/api/v1/assets', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          Cookie: sessionCookie,
        },
        body: JSON.stringify(validAssetData),
      })
    )
    expect(response.status).toBe(201)
  })
})
```

Reference: https://elysiajs.com/patterns/unit-test.html

