{
  "name": "city-os",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run --parallel --workspaces --if-present dev",
    "build": "bun run --sequential --workspaces --if-present build",
    "auth:schema:generate": "bun run --cwd ./packages/auth schema:generate",
    "auth:info": "bun run --cwd ./packages/auth info",
    "db:generate:migrations": "bun run --cwd ./packages/database db:generate",
    "db:migrate:check": "bun run --cwd ./packages/database db:check",
    "db:migrate": "bun run --cwd ./packages/database db:migrate",
    "db:fresh": "bun run --cwd ./packages/database db:fresh",
    "db:seed": "bun run --cwd ./packages/database db:seed",
    "serve": "bun run --parallel --workspaces --if-present serve",
    "lint:check": "ultracite check",
    "lint:fix": "ultracite fix",
    "lint:format": "biome format --write",
    "cache:clear": "bun run --parallel --workspaces --if-present cache:clear"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@types/bun": "latest",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.4",
    "ultracite": "7.7.0"
  },
  "peerDependencies": {
    "typescript": "^6"
  },
  "catalog": {
    "typescript": "^6.0.2"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "overrides": {
    "@sinclair/typebox": "0.34.49"
  },
  "lint-staged": {
    "*.{ts,json,css,md}": [
      "bun x ultracite fix"
    ]
  },
  "engines": {
    "bun": ">=1.3.13",
    "node": ">=22"
  }
}
