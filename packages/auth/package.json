{
  "name": "@city-os/auth",
  "exports": {
    "./server": "./src/auth.ts",
    "./client": "./src/auth-client.ts"
  },
  "scripts": {
    "cache:clear": "bun run ./src/scripts/clear-secondary-storage.ts",
    "schema:generate": "bunx --bun auth generate --config=./src/auth.ts --output=../database/src/schemas/auth.ts",
    "info": "bunx --bun auth info --config=./src/auth.ts"
  },
  "dependencies": {
    "@city-os/mailer": "workspace:*",
    "@city-os/database": "workspace:*",
    "@better-auth/redis-storage": "^1.6.11",
    "@paralleldrive/cuid2": "^3.3.0",
    "better-auth": "^1.6.11",
    "ioredis": "^5.10.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14"
  }
}
